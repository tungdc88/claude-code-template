{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Bash(git *)",
      "Bash(python3 -m pytest *)",
      "Bash(python3 *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "WebSearch",
      "WebFetch(*)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(*secret*)",
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(DROP *)",
      "Bash(DROP TABLE *)"
    ]
  },
  "env": {
    "PYTHONPATH": "."
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-tool-use.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-write.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/notify.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "outputStyle": "Concise",
  "respectGitignore": true,
  "plansDirectory": "docs",
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); model_id=$(echo \"$input\" | jq -r '.model.id // empty'); model_name=''; case \"$model_id\" in *opus-4.7*) model_name='opus' ;; *sonnet-4.6*) model_name='sonnet' ;; *haiku-4.5*) model_name='haiku' ;; *) model_name=$(echo \"$input\" | jq -r '.model.display_name // empty') ;; esac; used=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); if [ -n \"$used\" ]; then printf '%s %d%%' \"$model_name\" \"${used%.*}\"; else echo \"$model_name\"; fi"
  }
}
